---
import site from '../data/site.json';
const orderHref = site.orderUrl || '/order';
const orderTarget = site.orderUrl ? '_blank' : '_self';
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Olive Branch — home">
      <img src="/logo.png" alt="Olive Branch" class="brand-logo" width="220" height="56" />
    </a>
    <nav class="nav">
      <a href="/menu">Menu</a>
      <a href="/about">About</a>
      <a href="/contact">Visit</a>
      <a href={orderHref} class="btn btn-primary nav-cta" target={orderTarget} rel="noopener">
        Order Online
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--line);
    padding: var(--space-2) 0;
    background: var(--cream);
    position: relative;
    z-index: 10;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .brand {
    text-decoration: none;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
  }
  .brand-logo {
    display: block;
    height: 48px;
    width: auto;
    max-width: 180px;
    object-fit: contain;
  }
  @media (min-width: 768px) {
    .brand-logo { height: 56px; max-width: 220px; }
  }
  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .nav a:not(.btn) {
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--ink);
  }
  .nav a:not(.btn):hover { color: var(--terracotta); }
  .nav-cta {
    padding: 0.55rem 1.1rem;
    font-size: 0.875rem;
  }

  @media (max-width: 640px) {
    .nav a:not(.btn) { display: none; }
  }
</style>
