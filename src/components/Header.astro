---
import site from '../data/site.json';
const orderHref = site.orderUrl || '/order';
const orderTarget = site.orderUrl ? '_blank' : '_self';
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <span class="brand-mark">Olive Branch</span>
    </a>
    <nav class="nav">
      <a href="/menu">Menu</a>
      <a href="/about">About</a>
      <a href="/contact">Visit</a>
      <a href={orderHref} class="btn btn-primary nav-cta" target={orderTarget} rel="noopener">
        Order Online
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--line);
    padding: var(--space-2) 0;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .brand {
    text-decoration: none;
    color: var(--ink);
  }
  .brand-mark {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .nav a:not(.btn) {
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--ink);
  }
  .nav a:not(.btn):hover { color: var(--terracotta); }
  .nav-cta {
    padding: 0.55rem 1.1rem;
    font-size: 0.875rem;
  }

  @media (max-width: 640px) {
    .nav a:not(.btn) { display: none; }
  }
</style>