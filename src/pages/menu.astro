---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
import menu from '../data/menu.json';

import menuHero from '../assets/photos/IMG_0171.jpg';

const orderHref = site.orderUrl || '/order';
const orderTarget = site.orderUrl ? '_blank' : '_self';

function formatPrice(price) {
  if (!price || price === 0) return 'Ask';
  return `$${price.toFixed(2)}`;
}
---

<BaseLayout title="Menu">
  <section class="hero hero-interior">
    <Image
      src={menuHero}
      alt="Tzatziki, hummus, and dips with pita and warm spices on a stone counter"
      widths={[720, 1200, 1600, 2000]}
      sizes="100vw"
      loading="eager"
      class="hero-bg"
    />
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1 class="hero-title">Menu</h1>
      <p class="hero-sub">
        Carry-out only. Phone orders welcome.
        Online ordering {site.orderUrl ? 'is live' : 'launching soon'}.
      </p>
      <div class="hero-ctas">
        <a href={orderHref} class="btn btn-primary" target={orderTarget} rel="noopener">Order Online</a>
        <a href={`tel:${site.phone.tel}`} class="btn btn-secondary btn-on-dark">Call {site.phone.display}</a>
      </div>
    </div>
  </section>

  <section class="menu-body">
    <div class="container menu-container">
      {menu.sections.map(section => (
        <div class="menu-section">
          <h2 class="section-title">{section.name}</h2>
          <ul class="items">
            {section.items.map(item => (
              <li class="item">
                <div class="item-head">
                  <span class="item-name">{item.name}</span>
                  <span class="item-dots"></span>
                  <span class="item-price">{formatPrice(item.price)}</span>
                </div>
                {item.description && <p class="item-desc">{item.description}</p>}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="menu-cta">
    <div class="container menu-cta-inner">
      <h2><em>Ready to order?</em></h2>
      <a href={orderHref} class="btn btn-primary btn-large" target={orderTarget} rel="noopener">Order Online</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Shared full-bleed hero — interior pages (shorter than home) */
  .hero-interior {
    position: relative;
    min-height: min(60vh, 560px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
    text-align: center;
  }
  .hero-interior :global(.hero-bg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20, 17, 13, 0.4) 0%, rgba(20, 17, 13, 0.65) 100%);
    z-index: -1;
  }
  .hero-content {
    color: var(--cream);
    padding: var(--space-6) var(--space-3);
    max-width: 900px;
  }
  .hero-eyebrow {
    color: var(--cream-warm);
    margin-bottom: var(--space-3);
    opacity: 0.9;
  }
  .hero-title {
    color: var(--cream);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.35);
  }
  .hero-sub {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    color: var(--cream-warm);
    max-width: 38ch;
    margin: 0 auto var(--space-4);
    line-height: 1.5;
  }
  .hero-ctas {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    justify-content: center;
  }
  .btn-on-dark {
    color: var(--cream);
    border-color: var(--cream);
  }
  .btn-on-dark:hover {
    background: var(--cream);
    color: var(--ink);
  }

  .menu-body { padding: var(--space-7) 0; }
  .menu-container { max-width: 760px; }

  .menu-section {
    margin-bottom: var(--space-7);
  }
  .menu-section:last-child { margin-bottom: 0; }

  .section-title {
    font-style: italic;
    color: var(--olive-deep);
    border-bottom: 1px solid var(--line);
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .items { list-style: none; }
  .item {
    margin-bottom: var(--space-3);
  }
  .item-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 1.1rem;
  }
  .item-name { font-weight: 500; }
  .item-dots {
    flex: 1;
    border-bottom: 1px dotted var(--line);
    transform: translateY(-4px);
  }
  .item-price {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--olive-deep);
  }
  .item-desc {
    font-size: 0.95rem;
    color: var(--ink-soft);
    font-style: italic;
    margin-top: 0.25rem;
    margin-left: 0;
  }

  .menu-cta {
    background: var(--cream-warm);
    padding: var(--space-6) 0;
    text-align: center;
    border-top: 1px solid var(--line);
  }
  .menu-cta h2 {
    margin-bottom: var(--space-3);
  }
  .menu-cta h2 em { font-style: italic; color: var(--olive-deep); }
  .btn-large {
    padding: 1.1rem 2.5rem;
    font-size: 1.05rem;
  }
</style>
