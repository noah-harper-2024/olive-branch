---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
import menu from '../data/menu.json';

import menuHero from '../assets/photos/IMG_0171.jpg';

const orderHref = site.orderUrl || '/order';
const orderTarget = site.orderUrl ? '_blank' : '_self';

function formatPrice(price) {
  if (!price || price === 0) return 'Ask';
  return `$${price.toFixed(2)}`;
}
---

<BaseLayout title="Menu">
  <section class="menu-hero">
    <div class="container menu-hero-grid">
      <div class="menu-hero-copy">
        <p class="eyebrow">The kitchen</p>
        <h1><em>Menu.</em></h1>
        <p class="lede">
          Carry-out only. Phone orders welcome.
          Online ordering {site.orderUrl ? 'is live' : 'launching soon'}.
        </p>
        <div class="hero-ctas">
          <a href={orderHref} class="btn btn-primary" target={orderTarget} rel="noopener">Order Online</a>
          <a href={`tel:${site.phone.tel}`} class="btn btn-secondary">Call {site.phone.display}</a>
        </div>
      </div>
      <figure class="menu-hero-figure">
        <Image
          src={menuHero}
          alt="Tzatziki, hummus, and dips with pita and warm spices on a stone counter"
          widths={[400, 600, 800]}
          sizes="(min-width: 900px) 40vw, 100vw"
          loading="eager"
        />
      </figure>
    </div>
  </section>

  <section class="menu-body">
    <div class="container menu-container">
      {menu.sections.map(section => (
        <div class="menu-section">
          <h2 class="section-title">{section.name}</h2>
          <ul class="items">
            {section.items.map(item => (
              <li class="item">
                <div class="item-head">
                  <span class="item-name">{item.name}</span>
                  <span class="item-dots"></span>
                  <span class="item-price">{formatPrice(item.price)}</span>
                </div>
                {item.description && <p class="item-desc">{item.description}</p>}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="menu-cta">
    <div class="container menu-cta-inner">
      <h2><em>Ready to order?</em></h2>
      <a href={orderHref} class="btn btn-primary btn-large" target={orderTarget} rel="noopener">Order Online</a>
    </div>
  </section>
</BaseLayout>

<style>
  .menu-hero {
    padding: var(--space-6) 0 var(--space-6);
    border-bottom: 1px solid var(--line);
  }
  .menu-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  @media (min-width: 900px) {
    .menu-hero-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: var(--space-6);
    }
  }
  .menu-hero h1 {
    margin: var(--space-2) 0 var(--space-3);
    font-style: italic;
  }
  .menu-hero h1 em { font-style: italic; color: var(--olive-deep); font-weight: 300; }
  .lede {
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin-bottom: var(--space-3);
    line-height: 1.5;
    max-width: 38ch;
  }
  .hero-ctas { display: flex; gap: var(--space-2); flex-wrap: wrap; }

  .menu-hero-figure {
    margin: 0;
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 4 / 5;
  }
  .menu-hero-figure :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .menu-body { padding: var(--space-6) 0; }
  .menu-container { max-width: 760px; }

  .menu-section {
    margin-bottom: var(--space-7);
  }
  .menu-section:last-child { margin-bottom: 0; }

  .section-title {
    font-style: italic;
    color: var(--olive-deep);
    border-bottom: 1px solid var(--line);
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .items { list-style: none; }
  .item {
    margin-bottom: var(--space-3);
  }
  .item-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 1.1rem;
  }
  .item-name { font-weight: 500; }
  .item-dots {
    flex: 1;
    border-bottom: 1px dotted var(--line);
    transform: translateY(-4px);
  }
  .item-price {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--olive-deep);
  }
  .item-desc {
    font-size: 0.95rem;
    color: var(--ink-soft);
    font-style: italic;
    margin-top: 0.25rem;
    margin-left: 0;
  }

  .menu-cta {
    background: var(--cream-warm);
    padding: var(--space-6) 0;
    text-align: center;
    border-top: 1px solid var(--line);
  }
  .menu-cta h2 {
    margin-bottom: var(--space-3);
  }
  .menu-cta h2 em { font-style: italic; color: var(--olive-deep); }
  .btn-large {
    padding: 1.1rem 2.5rem;
    font-size: 1.05rem;
  }
</style>
