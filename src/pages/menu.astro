---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
import menu from '../data/menu.json';

const orderHref = site.orderUrl || '/order';
const orderTarget = site.orderUrl ? '_blank' : '_self';

function formatPrice(price) {
  if (!price || price === 0) return 'Ask';
  return `$${price.toFixed(2)}`;
}
---

<BaseLayout title="Menu">
  <section class="menu-hero">
    <div class="container">
      <p class="eyebrow">The kitchen</p>
      <h1>Menu</h1>
      <p class="lede">
        Carry-out only. Phone orders welcome.
        Online ordering {site.orderUrl ? 'is live' : 'launching soon'}.
      </p>
      <div class="hero-ctas">
        <a href={orderHref} class="btn btn-primary" target={orderTarget} rel="noopener">Order Online</a>
      </div>
    </div>
  </section>

  <section class="menu-body">
    <div class="container menu-container">
      {menu.sections.map(section => (
        <div class="menu-section">
          <h2 class="section-title">{section.name}</h2>
          <ul class="items">
            {section.items.map(item => (
              <li class="item">
                <div class="item-head">
                  <span class="item-name">{item.name}</span>
                  <span class="item-dots"></span>
                  <span class="item-price">{formatPrice(item.price)}</span>
                </div>
                {item.description && <p class="item-desc">{item.description}</p>}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="menu-cta">
    <div class="container menu-cta-inner">
      <h2>Ready to order?</h2>
      <a href={orderHref} class="btn btn-primary btn-large" target={orderTarget} rel="noopener">Order Online</a>
    </div>
  </section>
</BaseLayout>

<style>
  .menu-hero {
    padding: var(--space-6) 0 var(--space-5);
    border-bottom: 1px solid var(--line);
  }
  .menu-hero h1 {
    margin: var(--space-2) 0 var(--space-3);
  }
  .lede {
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin-bottom: var(--space-3);
  }
  .hero-ctas { display: flex; gap: var(--space-2); }

  .menu-body { padding: var(--space-6) 0; }
  .menu-container { max-width: 760px; }

  .menu-section {
    margin-bottom: var(--space-7);
  }
  .menu-section:last-child { margin-bottom: 0; }

  .section-title {
    font-style: italic;
    color: var(--olive-deep);
    border-bottom: 1px solid var(--line);
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .items { list-style: none; }
  .item {
    margin-bottom: var(--space-3);
  }
  .item-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 1.1rem;
  }
  .item-name { font-weight: 500; }
  .item-dots {
    flex: 1;
    border-bottom: 1px dotted var(--line);
    transform: translateY(-4px);
  }
  .item-price {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--olive-deep);
  }
  .item-desc {
    font-size: 0.95rem;
    color: var(--ink-soft);
    font-style: italic;
    margin-top: 0.25rem;
    margin-left: 0;
  }

  .menu-cta {
    background: var(--cream-warm);
    padding: var(--space-6) 0;
    text-align: center;
    border-top: 1px solid var(--line);
  }
  .menu-cta h2 {
    font-style: italic;
    margin-bottom: var(--space-3);
  }
  .btn-large {
    padding: 1.1rem 2.5rem;
    font-size: 1.05rem;
  }
</style>