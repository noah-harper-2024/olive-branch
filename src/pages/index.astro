---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

import hero from '../assets/photos/hero.jpg';
import bowls from '../assets/photos/IMG_0172.jpg';
import family from '../assets/photos/IMG_0173.jpg';
import mezze from '../assets/photos/IMG_0171.jpg';
import storyTable from '../assets/photos/IMG_0169.jpg';
import gallery1 from '../assets/photos/IMG_0168.jpg';
import gallery2 from '../assets/photos/IMG_0174.jpg';
import gallery3 from '../assets/photos/IMG_0170.jpg';
import gallery4 from '../assets/photos/falafel-sandwich.jpg';
import finalBg from '../assets/photos/falafel-sandwich.jpg';

const orderHref = site.orderUrl || '/order';
const orderTarget = site.orderUrl ? '_blank' : '_self';

const categories = [
  {
    title: "Rice Bowls",
    description: "Chicken or beef shawarma, gyro, shrimp, or kabob; over rice with our house sauce. $14.",
    image: bowls,
    alt: "Char-grilled chicken kabobs with vegetables and a side of tzatziki"
  },
  {
    title: "Family Dinner",
    description: "Lamb chop, shish kabob, steak kabob, or grilled chicken; six pieces, served with two large sides.",
    image: family,
    alt: "Chicken kabobs served over flatbread with cucumber, tomato, and dill yogurt"
  },
  {
    title: "Mezze",
    description: "Hummus, babaganoush, kibbeh, falafel; made by hand every morning, eaten with fresh pita.",
    image: mezze,
    alt: "Tzatziki, hummus, and dips with pita and warm spices on a stone counter"
  }
];

// Real Yelp reviews — all 5-star
const reviews = [
  {
    quote: "A sweet family running a family business with great customer service. The food is AMAZING. Definitely a repeat place for this crew.",
    name: "Patti B.",
    location: "San Angelo, TX"
  },
  {
    quote: "Middle Eastern dining with a casual price. Fresh food and generous portions. I subbed hummus for fries — they make their own. Locally owned and brand new. It won't disappoint.",
    name: "Rob S.",
    location: "Chatham, IL"
  },
  {
    quote: "If you like Mediterranean food this is the place to go. Small family business. Carry out. Check the menu out.",
    name: "ReKel H.",
    location: "O'Fallon, IL"
  },
  {
    quote: "Excellent Mediterranean food. Very friendly and yummy. I ordered the chicken shawarma and gyro, subbed in coleslaw and cucumber salad. All were delicious.",
    name: "Jessica P.",
    location: "Thornton, CO"
  },
  {
    quote: "Very friendly, quick, and the food is delicious. If you're looking for a place to get good food with awesome portions at a great price, Olive Branch is perfect!",
    name: "Aric L.",
    location: "Carmel, IN"
  },
  {
    quote: "The food here is simply AMAZING!! Delicious everything! My two teens loved it! Order your family dinner and bring home GREAT food!",
    name: "Alicia T.",
    location: "Illinois"
  }
];
---

<BaseLayout>
  <section class="hero hero-full">
    <Image
      src={hero}
      alt="Hummus, muhammara, and dips with olives on a green tiled table"
      widths={[720, 1200, 1600, 2000]}
      sizes="100vw"
      loading="eager"
      class="hero-bg"
    />
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <p class="eyebrow hero-eyebrow">{site.city} · Carry-out kitchen</p>
      <h1 class="hero-title">Olive Branch</h1>
      <p class="hero-sub">Authentic Mediterranean</p>
      <div class="hero-ctas">
        <a href={orderHref} class="btn btn-primary" target={orderTarget} rel="noopener">Order Online</a>
        <a href="/menu" class="btn btn-secondary btn-on-dark">See the Menu</a>
      </div>
    </div>
  </section>

  <div class="marquee">
    <div class="container marquee-inner">
      <span><em>Carry-out only</em></span>
      <span class="dot">·</span>
      <span>{site.address.street}</span>
      <span class="dot">·</span>
      <span>Open today, 11–9</span>
      <span class="dot">·</span>
      <span><a href={`tel:${site.phone.tel}`}>{site.phone.display}</a></span>
    </div>
  </div>

  <section class="categories">
    <div class="container">
      <header class="section-header">
        <p class="eyebrow">What we cook</p>
        <h2 class="section-title">Three things, done well.</h2>
      </header>
      <div class="cat-grid">
        {categories.map(c => (
          <article class="cat-card">
            <div class="cat-image">
              <Image
                src={c.image}
                alt={c.alt}
                widths={[400, 600, 800]}
                sizes="(min-width: 900px) 32vw, 100vw"
                loading="lazy"
              />
            </div>
            <h3>{c.title}</h3>
            <p>{c.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="story">
    <div class="container story-grid">
      <figure class="story-figure">
        <Image
          src={storyTable}
          alt="Sunlit Mediterranean table with hummus, pita, olives, and an olive branch"
          widths={[400, 600, 800]}
          sizes="(min-width: 900px) 45vw, 100vw"
          loading="lazy"
        />
      </figure>
      <div class="story-copy">
        <p class="eyebrow">The kitchen</p>
        <p class="story-text">
          Olive Branch is a small, family-run Mediterranean kitchen.
          <em>Everything cooked fresh, from the heart.</em>
        </p>
        <p class="story-sub">
          The hummus is whipped fresh in the morning. The kabobs come off the grill
          seared and tender. The pita comes out of the oven all day. Come pick up dinner.
        </p>
        <a href="/about" class="story-link">More about the kitchen →</a>
      </div>
    </div>
  </section>

  <section class="gallery">
    <div class="gallery-strip">
      <figure>
        <Image src={gallery1} alt="Mediterranean spread with grilled vegetables, feta, and olives" widths={[300, 500, 700]} sizes="(min-width: 900px) 25vw, 50vw" loading="lazy" />
      </figure>
      <figure>
        <Image src={gallery2} alt="Mediterranean wrap with shawarma, pickled onions, herbs, and fries" widths={[300, 500, 700]} sizes="(min-width: 900px) 25vw, 50vw" loading="lazy" />
      </figure>
      <figure>
        <Image src={gallery3} alt="Greek salad with feta shared at a stone table by the sea" widths={[300, 500, 700]} sizes="(min-width: 900px) 25vw, 50vw" loading="lazy" />
      </figure>
      <figure>
        <Image src={gallery4} alt="Falafel sandwiches stacked in pita with tahini, hot sauce, and pickles" widths={[300, 500, 700]} sizes="(min-width: 900px) 25vw, 50vw" loading="lazy" />
      </figure>
    </div>
  </section>

  <section class="reviews">
    <div class="container">
      <header class="section-header reviews-header">
        <p class="eyebrow">What people say</p>
        <p class="reviews-summary">
          <span class="summary-stars" aria-hidden="true">★★★★★</span>
          <span class="summary-text">5.0 on Yelp · {reviews.length} reviews</span>
        </p>
      </header>

      <div class="reviews-carousel" data-reviews>
        <div class="reviews-track" aria-live="polite">
          {reviews.map((r, i) => (
            <blockquote class={`review-card ${i === 0 ? 'is-active' : ''}`} data-index={i}>
              <div class="review-stars" aria-label="5 out of 5 stars">★★★★★</div>
              <p class="review-quote">“{r.quote}”</p>
              <footer class="review-attr">
                — {r.name}{r.location ? `, ${r.location}` : ''} · <span>Yelp</span>
              </footer>
            </blockquote>
          ))}
        </div>

        <div class="review-dots" role="tablist" aria-label="Choose review">
          {reviews.map((_, i) => (
            <button
              type="button"
              class={`dot ${i === 0 ? 'is-active' : ''}`}
              data-go={i}
              role="tab"
              aria-label={`Show review ${i + 1} of ${reviews.length}`}
            ></button>
          ))}
        </div>
      </div>

      <p class="reviews-link">
        <a href="https://www.yelp.com/biz/olive-branch-o-fallon" target="_blank" rel="noopener">Read more on Yelp →</a>
      </p>
    </div>
  </section>

  <script is:inline>
    (() => {
      const carousel = document.querySelector('[data-reviews]');
      if (!carousel) return;
      const cards = carousel.querySelectorAll('.review-card');
      const dots = carousel.querySelectorAll('.dot');
      if (!cards.length) return;

      let current = 0;
      let timer = null;
      const ROTATE_MS = 7000;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function show(i) {
        cards[current].classList.remove('is-active');
        dots[current].classList.remove('is-active');
        current = (i + cards.length) % cards.length;
        cards[current].classList.add('is-active');
        dots[current].classList.add('is-active');
      }
      function next() { show(current + 1); }
      function start() {
        stop();
        if (reduceMotion) return;
        timer = setInterval(next, ROTATE_MS);
      }
      function stop() {
        if (timer) { clearInterval(timer); timer = null; }
      }

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => { show(i); start(); });
      });
      carousel.addEventListener('mouseenter', stop);
      carousel.addEventListener('mouseleave', start);
      carousel.addEventListener('focusin', stop);
      carousel.addEventListener('focusout', start);

      start();
    })();
  </script>

  <section class="final-cta">
    <Image
      src={finalBg}
      alt=""
      widths={[600, 1000, 1600]}
      sizes="100vw"
      loading="lazy"
      class="final-bg"
    />
    <div class="final-overlay"></div>
    <div class="container final-cta-inner">
      <p class="eyebrow">Hungry?</p>
      <h2><em>Pick up dinner.</em></h2>
      <p class="final-sub">
        Order online for pickup. Ready in about {site.orderUrl ? '20' : '15–25'} minutes.
      </p>
      <a href={orderHref} class="btn btn-primary btn-large" target={orderTarget} rel="noopener">Order Online</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO — full-bleed, edge to edge */
  .hero-full {
    position: relative;
    min-height: min(85vh, 820px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
    text-align: center;
  }
  .hero-full :global(.hero-bg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20, 17, 13, 0.35) 0%, rgba(20, 17, 13, 0.6) 100%);
    z-index: -1;
  }
  .hero-content {
    color: var(--cream);
    padding: var(--space-6) var(--space-3);
    max-width: 900px;
  }
  .hero-eyebrow {
    color: var(--cream-warm);
    margin: 0 auto var(--space-3);
    opacity: 0.9;
  }
  .hero-title {
    color: var(--cream);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.35);
  }
  .hero-sub {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    color: var(--cream-warm);
    max-width: 38ch;
    margin: 0 auto var(--space-4);
    line-height: 1.5;
    font-style: italic;
  }
  .hero-ctas {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    justify-content: center;
  }
  /* Light variant of secondary button on dark hero */
  .btn-on-dark {
    color: var(--cream);
    border-color: var(--cream);
  }
  .btn-on-dark:hover {
    background: var(--cream);
    color: var(--ink);
  }

  /* MARQUEE band */
  .marquee {
    background: var(--ink);
    color: var(--cream);
    padding: 0.85rem 0;
    overflow: hidden;
  }
  .marquee-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    font-size: 0.875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .marquee em { color: var(--cream-warm); font-style: italic; text-transform: none; letter-spacing: 0; font-size: 1rem; }
  .marquee .dot { color: var(--olive); opacity: 0.6; }
  .marquee a { color: var(--cream); text-decoration: none; }
  .marquee a:hover { color: var(--terracotta); }

  /* SECTION HELPERS */
  .section-header {
    margin-bottom: var(--space-5);
    max-width: 720px;
  }
  .section-title {
    font-style: italic;
    margin-top: var(--space-2);
    color: var(--ink);
  }

  /* CATEGORIES */
  .categories {
    padding: var(--space-7) 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .cat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 768px) {
    .cat-grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-4); }
  }
  .cat-card {
    display: flex;
    flex-direction: column;
  }
  .cat-image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 3px;
    margin-bottom: var(--space-3);
    background: var(--cream-warm);
  }
  .cat-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 700ms ease;
  }
  .cat-card:hover .cat-image :global(img) {
    transform: scale(1.04);
  }
  .cat-card h3 {
    font-style: italic;
    color: var(--olive-deep);
    margin-bottom: var(--space-1);
  }
  .cat-card p {
    color: var(--ink-soft);
    font-size: 1.05rem;
  }

  /* STORY — alternating two-column */
  .story { padding: var(--space-7) 0; }
  .story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  @media (min-width: 900px) {
    .story-grid {
      grid-template-columns: 1fr 1.1fr;
      gap: var(--space-7);
    }
  }
  .story-figure {
    margin: 0;
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 4 / 5;
  }
  .story-figure :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .story-copy { max-width: 520px; }
  .story-text {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.25;
    margin: var(--space-3) 0 var(--space-3);
    font-weight: 300;
    color: var(--ink);
  }
  .story-text em {
    font-style: italic;
    color: var(--olive-deep);
  }
  .story-sub {
    color: var(--ink-soft);
    font-size: 1.05rem;
    margin-bottom: var(--space-3);
    line-height: 1.6;
  }
  .story-link {
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--terracotta);
    font-weight: 500;
  }
  .story-link:hover { color: var(--terracotta-deep); }

  /* GALLERY strip */
  .gallery {
    background: var(--cream-warm);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .gallery-strip {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }
  @media (min-width: 768px) {
    .gallery-strip { grid-template-columns: repeat(4, 1fr); }
  }
  .gallery-strip figure {
    margin: 0;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--ink);
  }
  .gallery-strip figure :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 800ms ease;
    filter: saturate(1.05);
  }
  .gallery-strip figure:hover :global(img) {
    transform: scale(1.05);
  }

  /* REVIEWS — auto-rotating carousel */
  .reviews {
    padding: var(--space-7) 0;
  }
  .reviews-header {
    text-align: center;
    margin: 0 auto var(--space-5);
  }
  .reviews-summary {
    margin: var(--space-2) auto 0;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .summary-stars {
    color: #c99a4d;
    letter-spacing: 0.1em;
    font-size: 1.1rem;
  }
  .summary-text {
    color: var(--ink-soft);
    font-size: 0.95rem;
    font-style: italic;
  }

  .reviews-carousel {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
  }
  .reviews-track {
    display: grid;
  }
  .review-card {
    grid-area: 1 / 1;
    text-align: center;
    padding: 0 var(--space-2);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 600ms ease, transform 600ms ease;
    pointer-events: none;
  }
  .review-card.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    .review-card { transition: none; transform: none; }
  }
  .review-stars {
    color: #c99a4d;
    letter-spacing: 0.18em;
    font-size: 1.15rem;
    margin-bottom: var(--space-3);
  }
  .review-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    line-height: 1.45;
    color: var(--ink);
    margin: 0 auto var(--space-3);
    max-width: 60ch;
  }
  .review-attr {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }
  .review-attr span { font-style: italic; color: var(--olive-deep); }

  .review-dots {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    margin-top: var(--space-4);
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1px solid var(--olive);
    background: transparent;
    padding: 0;
    cursor: pointer;
    transition: background 200ms ease, transform 200ms ease;
  }
  .dot:hover { background: var(--olive); transform: scale(1.15); }
  .dot.is-active { background: var(--olive); }
  .dot:focus-visible {
    outline: 2px solid var(--terracotta);
    outline-offset: 3px;
  }

  .reviews-link {
    text-align: center;
    margin-top: var(--space-4);
    font-size: 0.95rem;
  }
  .reviews-link a {
    color: var(--terracotta);
    text-decoration: none;
  }
  .reviews-link a:hover { color: var(--terracotta-deep); }

  /* FINAL CTA — full-bleed photo */
  .final-cta {
    position: relative;
    padding: var(--space-8) 0;
    text-align: center;
    overflow: hidden;
    isolation: isolate;
  }
  .final-cta :global(.final-bg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }
  .final-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(42, 38, 32, 0.55), rgba(42, 38, 32, 0.85));
    z-index: -1;
  }
  .final-cta-inner {
    max-width: 640px;
    color: var(--cream);
  }
  .final-cta .eyebrow { color: var(--cream-warm); opacity: 0.85; }
  .final-cta h2 {
    color: var(--cream);
    font-style: italic;
    margin: var(--space-2) 0 var(--space-3);
  }
  .final-cta h2 em {
    font-style: italic;
    color: var(--cream);
  }
  .final-sub {
    color: var(--cream-warm);
    margin: 0 auto var(--space-4);
    font-size: 1.15rem;
    max-width: 38ch;
  }
  .btn-large {
    padding: 1.1rem 2.5rem;
    font-size: 1.05rem;
  }
  .final-cta .btn-primary {
    background: var(--cream);
    color: var(--ink);
    border-color: var(--cream);
  }
  .final-cta .btn-primary:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
    color: var(--cream);
  }
</style>
