---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const orderHref = site.orderUrl || '/order';
const orderTarget = site.orderUrl ? '_blank' : '_self';

const categories = [
  {
    title: "Off the Grill",
    description: "Kabobs and lamb chops. Marinated, charred, served over rice with salad."
  },
  {
    title: "The Rotisserie",
    description: "Whole or half chickens, seasoned the night before, slow-roasted on the spit."
  },
  {
    title: "Sandwiches & Wraps",
    description: "Shawarma carved off the vertical spit. Falafel fried to order. Pita fresh."
  }
];

// Placeholder reviews — replace with real ones from Yelp/Google before launch
const reviews = [
  {
    quote: "Add a real review from Yelp or Google here.",
    name: "Reviewer Name",
    source: "Google"
  },
  {
    quote: "Add a real review from Yelp or Google here.",
    name: "Reviewer Name",
    source: "Yelp"
  },
  {
    quote: "Add a real review from Yelp or Google here.",
    name: "Reviewer Name",
    source: "Google"
  }
];
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">{site.city} · Carry-out kitchen</p>
      <h1 class="hero-title">
        Authentic<br />
        <em>Mediterranean.</em>
      </h1>
      <p class="hero-lede">
        Off the grill. Rotisserie chicken on the spit. Hummus and pita made fresh.
        Family recipes, served quick, in a quiet corner of {site.city}.
      </p>
      <div class="hero-ctas">
        <a href={orderHref} class="btn btn-primary" target={orderTarget} rel="noopener">Order Online</a>
        <a href="/menu" class="btn btn-secondary">See the Menu</a>
      </div>
    </div>
  </section>

  <section class="categories">
    <div class="container">
      <p class="eyebrow section-eyebrow">What we cook</p>
      <div class="cat-grid">
        {categories.map(c => (
          <article class="cat-card">
            <h3>{c.title}</h3>
            <p>{c.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="story">
    <div class="container story-inner">
      <p class="eyebrow">The kitchen</p>
      <p class="story-text">
        Olive Branch is a small, family-run Mediterranean kitchen. We make food the way it should be made —
        by hand, every day, with no shortcuts. Come pick up dinner.
      </p>
      <a href="/about" class="story-link">More about the kitchen →</a>
    </div>
  </section>

  <section class="reviews">
    <div class="container">
      <p class="eyebrow section-eyebrow">What people say</p>
      <div class="review-grid">
        {reviews.map(r => (
          <blockquote class="review">
            <p class="review-quote">“{r.quote}”</p>
            <footer class="review-attr">— {r.name}, <span>{r.source}</span></footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container final-cta-inner">
      <h2>Hungry?</h2>
      <p>Order online for pickup. Ready in about {site.orderUrl ? '20' : '15–25'} minutes.</p>
      <a href={orderHref} class="btn btn-primary btn-large" target={orderTarget} rel="noopener">Order Online</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    padding: var(--space-7) 0 var(--space-7);
    position: relative;
  }
  .hero-inner { max-width: 900px; }
  .hero-title {
    margin: var(--space-3) 0 var(--space-4);
    line-height: 0.95;
  }
  .hero-title em {
    font-style: italic;
    color: var(--olive-deep);
    font-weight: 300;
  }
  .hero-lede {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    color: var(--ink-soft);
    max-width: 36ch;
    margin-bottom: var(--space-4);
    line-height: 1.5;
  }
  .hero-ctas { display: flex; gap: var(--space-2); flex-wrap: wrap; }

  /* SECTION HELPERS */
  .section-eyebrow { margin-bottom: var(--space-4); }

  /* CATEGORIES */
  .categories {
    padding: var(--space-6) 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--cream-warm);
  }
  .cat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 768px) {
    .cat-grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  }
  .cat-card h3 {
    font-style: italic;
    color: var(--olive-deep);
    margin-bottom: var(--space-2);
  }
  .cat-card p {
    color: var(--ink-soft);
    font-size: 1.05rem;
  }

  /* STORY */
  .story { padding: var(--space-7) 0; }
  .story-inner { max-width: 720px; }
  .story-text {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.3;
    margin: var(--space-3) 0 var(--space-3);
    font-weight: 300;
  }
  .story-link {
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--terracotta);
  }
  .story-link:hover { color: var(--terracotta-deep); }

  /* REVIEWS */
  .reviews {
    padding: var(--space-6) 0;
    border-top: 1px solid var(--line);
  }
  .review-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 768px) {
    .review-grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  }
  .review {
    border-left: 2px solid var(--olive);
    padding-left: var(--space-3);
  }
  .review-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.4;
    color: var(--ink);
    margin-bottom: var(--space-2);
  }
  .review-attr {
    font-size: 0.9rem;
    color: var(--ink-soft);
  }
  .review-attr span { font-style: italic; }

  /* FINAL CTA */
  .final-cta {
    background: var(--ink);
    color: var(--cream);
    padding: var(--space-7) 0;
    text-align: center;
  }
  .final-cta-inner { max-width: 600px; margin: 0 auto; }
  .final-cta h2 {
    color: var(--cream);
    font-style: italic;
    margin-bottom: var(--space-2);
  }
  .final-cta p {
    color: var(--cream-warm);
    margin: 0 auto var(--space-4);
    font-size: 1.15rem;
  }
  .btn-large {
    padding: 1.1rem 2.5rem;
    font-size: 1.05rem;
  }
</style>