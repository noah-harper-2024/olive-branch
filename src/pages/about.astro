---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

import aboutHero from '../assets/photos/IMG_0168.jpg';
import aboutMid from '../assets/photos/IMG_0170.jpg';
---

<BaseLayout title="About">
  <section class="about-hero">
    <div class="container about-hero-grid">
      <div class="about-hero-copy">
        <p class="eyebrow">About</p>
        <h1>The <em>Kitchen.</em></h1>
        <p class="lead">
          Olive Branch is a small, family-run Mediterranean kitchen in {site.city}.
          We're new to town. The recipes are not.
        </p>
      </div>
      <figure class="about-hero-figure">
        <Image
          src={aboutHero}
          alt="A rustic Mediterranean spread of grilled vegetables, feta, olives, hummus, and warm pita on a wood table"
          widths={[400, 600, 800]}
          sizes="(min-width: 900px) 45vw, 100vw"
          loading="eager"
        />
      </figure>
    </div>
  </section>

  <section class="about-body">
    <div class="container about-body-inner">
      <div class="prose">
        <p>
          Everything we serve is cooked the way it's been cooked for generations.
          The shawarma turns on a vertical spit until the edges crisp. The rotisserie
          chickens go in whole, seasoned the night before. The hummus, the tahini,
          the pita — made in the kitchen, every morning. Nothing comes out of a bag.
        </p>

        <p>
          We're carry-out only for now. Order ahead, swing by, take it home hot.
        </p>
      </div>

      <div class="values">
        <div class="value">
          <h3>Authentic</h3>
          <p>Real recipes, the way they're meant to be cooked. No shortcuts, no fusion.</p>
        </div>
        <div class="value">
          <h3>By hand</h3>
          <p>Hummus, tahini, pita, marinades — made in the kitchen, every day.</p>
        </div>
        <div class="value">
          <h3>Quick</h3>
          <p>Carry-out only. In and out. Hot food, no wait.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-banner">
    <Image
      src={aboutMid}
      alt="Hands sharing a Greek salad with feta at a stone table overlooking the sea"
      widths={[600, 1000, 1600]}
      sizes="100vw"
      loading="lazy"
      class="banner-img"
    />
  </section>

  <section class="about-cta">
    <div class="container">
      <p class="eyebrow">Visit</p>
      <p class="address-line">{site.address.street}, {site.address.cityState}</p>
      <a href="/contact" class="btn btn-secondary">Hours & Directions</a>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding: var(--space-6) 0 var(--space-7);
  }
  .about-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  @media (min-width: 900px) {
    .about-hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-7);
    }
  }
  .about-hero h1 {
    margin: var(--space-2) 0 var(--space-4);
  }
  .about-hero h1 em {
    font-style: italic;
    color: var(--olive-deep);
    font-weight: 300;
  }
  .lead {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 1.85rem);
    line-height: 1.35;
    color: var(--ink);
    font-weight: 300;
    max-width: 30ch;
  }
  .about-hero-figure {
    margin: 0;
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 4 / 5;
  }
  .about-hero-figure :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-body {
    padding: var(--space-6) 0 var(--space-7);
    border-top: 1px solid var(--line);
  }
  .about-body-inner { max-width: 720px; }

  .prose p {
    font-size: 1.15rem;
    line-height: 1.65;
    margin-bottom: var(--space-3);
    color: var(--ink);
  }

  .values {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    border-top: 1px solid var(--line);
    padding-top: var(--space-5);
  }
  @media (min-width: 768px) {
    .values { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  }
  .value h3 {
    font-style: italic;
    color: var(--olive-deep);
    margin-bottom: var(--space-1);
  }
  .value p {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }

  .about-banner {
    position: relative;
    overflow: hidden;
    aspect-ratio: 21 / 9;
    background: var(--ink);
  }
  @media (max-width: 768px) {
    .about-banner { aspect-ratio: 4 / 3; }
  }
  .about-banner :global(.banner-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-cta {
    background: var(--cream-warm);
    padding: var(--space-5) 0;
    border-top: 1px solid var(--line);
    text-align: center;
  }
  .address-line {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin: var(--space-1) 0 var(--space-3);
  }
</style>
