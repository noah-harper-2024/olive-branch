---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout title="About">
  <section class="about-hero">
    <div class="container about-container">
      <p class="eyebrow">About</p>
      <h1>The Kitchen</h1>

      <div class="prose">
        <p class="lead">
          Olive Branch is a small, family-run Mediterranean kitchen in {site.city}.
          We're new to town. The recipes are not.
        </p>

        <p>
          Everything we serve is cooked the way it's been cooked for generations.
          The shawarma turns on a vertical spit until the edges crisp. The rotisserie
          chickens go in whole, seasoned the night before. The hummus, the tahini,
          the pita — made in the kitchen, every morning. Nothing comes out of a bag.
        </p>

        <p>
          We're carry-out only for now. Order ahead, swing by, take it home hot.
        </p>
      </div>

      <div class="values">
        <div class="value">
          <h3>Authentic</h3>
          <p>Real recipes, the way they're meant to be cooked. No shortcuts, no fusion.</p>
        </div>
        <div class="value">
          <h3>By hand</h3>
          <p>Hummus, tahini, pita, marinades — made in the kitchen, every day.</p>
        </div>
        <div class="value">
          <h3>Quick</h3>
          <p>Carry-out only. In and out. Hot food, no wait.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-cta">
    <div class="container">
      <p class="eyebrow">Visit</p>
      <p class="address-line">{site.address.street}, {site.address.cityState}</p>
      <a href="/contact" class="btn btn-secondary">Hours & Directions</a>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero { padding: var(--space-6) 0 var(--space-7); }
  .about-container { max-width: 720px; }
  .about-hero h1 { margin: var(--space-2) 0 var(--space-5); }

  .prose p {
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: var(--space-3);
    color: var(--ink);
  }
  .prose .lead {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.3;
    color: var(--ink);
    margin-bottom: var(--space-4);
    font-weight: 300;
  }

  .values {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    border-top: 1px solid var(--line);
    padding-top: var(--space-5);
  }
  @media (min-width: 768px) {
    .values { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  }
  .value h3 {
    font-style: italic;
    color: var(--olive-deep);
    margin-bottom: var(--space-1);
  }
  .value p {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }

  .about-cta {
    background: var(--cream-warm);
    padding: var(--space-5) 0;
    border-top: 1px solid var(--line);
    text-align: center;
  }
  .address-line {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin: var(--space-1) 0 var(--space-3);
  }
</style>