---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

import aboutHero from '../assets/photos/IMG_0168.jpg';
---

<BaseLayout title="About">
  <section class="hero hero-interior">
    <Image
      src={aboutHero}
      alt="A rustic Mediterranean spread of grilled vegetables, feta, olives, hummus, and warm pita on a wood table"
      widths={[720, 1200, 1600, 2000]}
      sizes="100vw"
      loading="eager"
      class="hero-bg"
    />
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1 class="hero-title">The Kitchen</h1>
      <p class="hero-sub">
        A small, family-run Mediterranean kitchen in {site.city}.
        We're new to town. The recipes are not.
      </p>
    </div>
  </section>

  <section class="about-body">
    <div class="container about-body-inner">
      <div class="prose">
        <p>
          Everything we serve is cooked the way it's been cooked for generations.
          The shawarma turns on a vertical spit until the edges crisp. The lamb
          chops come off the grill seared and tender. The hummus, the tahini,
          the pita — made in the kitchen, every morning. Nothing comes out of a bag.
        </p>

        <p>
          We're carry-out only for now. Order ahead, swing by, take it home hot.
        </p>
      </div>

      <div class="values">
        <div class="value">
          <h3>Authentic</h3>
          <p>Real recipes, the way they're meant to be cooked. No shortcuts, no fusion.</p>
        </div>
        <div class="value">
          <h3>By hand</h3>
          <p>Hummus, tahini, pita, marinades — made in the kitchen, every day.</p>
        </div>
        <div class="value">
          <h3>Quick</h3>
          <p>Carry-out only. In and out. Hot food, no wait.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-cta">
    <div class="container">
      <p class="eyebrow">Visit</p>
      <p class="address-line">{site.address.street}, {site.address.cityState}</p>
      <a href="/contact" class="btn btn-secondary">Hours & Directions</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Shared full-bleed hero — interior pages */
  .hero-interior {
    position: relative;
    min-height: min(60vh, 560px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
    text-align: center;
  }
  .hero-interior :global(.hero-bg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20, 17, 13, 0.4) 0%, rgba(20, 17, 13, 0.65) 100%);
    z-index: -1;
  }
  .hero-content {
    color: var(--cream);
    padding: var(--space-6) var(--space-3);
    max-width: 900px;
  }
  .hero-eyebrow {
    color: var(--cream-warm);
    margin-bottom: var(--space-3);
    opacity: 0.9;
  }
  .hero-title {
    color: var(--cream);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.35);
  }
  .hero-sub {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    color: var(--cream-warm);
    max-width: 42ch;
    margin: 0 auto var(--space-4);
    line-height: 1.5;
  }

  .about-body {
    padding: var(--space-7) 0;
  }
  .about-body-inner { max-width: 720px; }

  .prose p {
    font-size: 1.15rem;
    line-height: 1.65;
    margin-bottom: var(--space-3);
    color: var(--ink);
  }

  .values {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    border-top: 1px solid var(--line);
    padding-top: var(--space-5);
  }
  @media (min-width: 768px) {
    .values { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  }
  .value h3 {
    font-style: italic;
    color: var(--olive-deep);
    margin-bottom: var(--space-1);
  }
  .value p {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }

  .about-cta {
    background: var(--cream-warm);
    padding: var(--space-5) 0;
    border-top: 1px solid var(--line);
    text-align: center;
  }
  .address-line {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin: var(--space-1) 0 var(--space-3);
  }
</style>
