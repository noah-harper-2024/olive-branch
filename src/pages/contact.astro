---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

import contactHero from '../assets/photos/IMG_0173.jpg';
---

<BaseLayout title="Visit">
  <section class="contact-hero">
    <div class="container contact-hero-grid">
      <div class="contact-hero-copy">
        <p class="eyebrow">Visit</p>
        <h1><em>Find us.</em></h1>

        <div class="info-grid">
          <div class="info-block">
            <p class="eyebrow">Address</p>
            <p class="info-text">
              {site.address.street}<br />
              {site.address.cityState}
            </p>
            <a href={site.mapsUrl} class="btn btn-secondary" target="_blank" rel="noopener">
              Get Directions
            </a>
          </div>

          <div class="info-block">
            <p class="eyebrow">Phone</p>
            <p class="info-text">
              <a href={`tel:${site.phone.tel}`}>{site.phone.display}</a>
            </p>
            <a href={`tel:${site.phone.tel}`} class="btn btn-secondary">Call to Order</a>
          </div>
        </div>

        <div class="info-block info-hours">
          <p class="eyebrow">Hours</p>
          <ul class="hours-list">
            {site.hours.map(h => (
              <li>
                <span>{h.days}</span>
                <span>{h.note ? h.note : `${h.open} – ${h.close}`}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <figure class="contact-hero-figure">
        <Image
          src={contactHero}
          alt="Chicken kabobs over flatbread with cucumber, tomato, and dill yogurt"
          widths={[400, 600, 800]}
          sizes="(min-width: 900px) 40vw, 100vw"
          loading="eager"
        />
      </figure>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero { padding: var(--space-6) 0 var(--space-7); }
  .contact-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: start;
  }
  @media (min-width: 900px) {
    .contact-hero-grid {
      grid-template-columns: 1.2fr 1fr;
      gap: var(--space-6);
    }
  }
  .contact-hero h1 {
    margin: var(--space-2) 0 var(--space-5);
  }
  .contact-hero h1 em {
    font-style: italic;
    color: var(--olive-deep);
    font-weight: 300;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    margin-bottom: var(--space-5);
  }
  @media (min-width: 480px) {
    .info-grid { grid-template-columns: 1fr 1fr; gap: var(--space-4); }
  }

  .info-block .eyebrow { margin-bottom: var(--space-2); }
  .info-text {
    font-family: var(--font-display);
    font-size: 1.4rem;
    line-height: 1.4;
    margin-bottom: var(--space-3);
  }
  .info-text a { text-decoration: none; }

  .info-hours {
    border-top: 1px solid var(--line);
    padding-top: var(--space-4);
  }

  .hours-list { list-style: none; }
  .hours-list li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--line);
    font-size: 1rem;
  }
  .hours-list li:last-child { border-bottom: none; }

  .contact-hero-figure {
    margin: 0;
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 4 / 5;
    position: sticky;
    top: var(--space-4);
  }
  @media (max-width: 900px) {
    .contact-hero-figure { position: static; }
  }
  .contact-hero-figure :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
