---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout title="Visit">
  <section class="contact-hero">
    <div class="container contact-container">
      <p class="eyebrow">Visit</p>
      <h1>Find us.</h1>

      <div class="info-grid">
        <div class="info-block">
          <p class="eyebrow">Address</p>
          <p class="info-text">
            {site.address.street}<br />
            {site.address.cityState}
          </p>
          <a href={site.mapsUrl} class="btn btn-secondary" target="_blank" rel="noopener">
            Get Directions
          </a>
        </div>

        <div class="info-block">
          <p class="eyebrow">Phone</p>
          <p class="info-text">
            <a href={`tel:${site.phone.tel}`}>{site.phone.display}</a>
          </p>
          <a href={`tel:${site.phone.tel}`} class="btn btn-secondary">Call to Order</a>
        </div>

        <div class="info-block info-hours">
          <p class="eyebrow">Hours</p>
          <ul class="hours-list">
            {site.hours.map(h => (
              <li>
                <span>{h.days}</span>
                <span>{h.note ? h.note : `${h.open} – ${h.close}`}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero { padding: var(--space-6) 0 var(--space-7); }
  .contact-container { max-width: 1000px; }
  .contact-hero h1 {
    margin: var(--space-2) 0 var(--space-5);
    font-style: italic;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 768px) {
    .info-grid { grid-template-columns: 1fr 1fr 1.2fr; gap: var(--space-6); }
  }

  .info-block .eyebrow { margin-bottom: var(--space-2); }
  .info-text {
    font-family: var(--font-display);
    font-size: 1.4rem;
    line-height: 1.4;
    margin-bottom: var(--space-3);
  }
  .info-text a { text-decoration: none; }

  .hours-list { list-style: none; }
  .hours-list li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--line);
    font-size: 1rem;
  }
  .hours-list li:last-child { border-bottom: none; }
</style>